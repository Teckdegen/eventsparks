# ─────────────────────────────────────────────
# EventSparks — Environment Variables
# Copy this file to .env and fill in the values
# ─────────────────────────────────────────────

# --------------------------------------------------
# SUPABASE (required)
# Get these from: https://supabase.com/dashboard → project → Settings → API
# --------------------------------------------------
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-public-key

# --------------------------------------------------
# ADMIN LOGIN (required)
# Credentials used to log into the admin dashboard
# --------------------------------------------------
VITE_ADMIN_EMAIL=admin@example.com
VITE_ADMIN_PASSWORD=your-secure-admin-password

# --------------------------------------------------
# SUPABASE EDGE FUNCTIONS — server-side secrets
# Set these in: https://supabase.com/dashboard → project → Edge Functions → Secrets
# (These are NOT prefixed with VITE_ — they run on the server only)
# --------------------------------------------------

# Supabase service role key — used by admin-events edge function
# Get from: Supabase dashboard → Settings → API → service_role key (keep secret!)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Lovable AI API key — used by the chat edge function
# Get from: https://lovable.dev/dashboard → API Keys
LOVABLE_API_KEY=your-lovable-api-key
